configuration {
  modi: "drun,run,window,ssh";
  show-icons: false;
  display-drun: "󰀻 APPS";
  display-run: "󰆍 RUN";
  display-window: "󰖯 WIN";
  display-ssh: "󰣀 SSH";
  drun-display-format: "{name}";
  font: "MonaspiceNe Nerd Font 12";
}

/*
 * Kanagawa Dragon — editorial minimalism.
 * One rounded slab, no borders. Selection and the search field are
 * soft fills, not outlines. Whitespace does the separating.
 */
* {
  base00: #181616; /* Main Background */
  base01: #1D1C19; /* Soft fill (search, selected tab) */
  base02: #282727; /* Selected row fill */
  base03: #625e5a; /* Muted ink */
  base05: #c5c9c5; /* Foreground */
  base08: #8ea4a2; /* Aqua */
  base0A: #c4746e; /* Red/High Status */
  base0C: #b6927b; /* Orange */
  base0E: #c4b28a; /* Sand/Primary */

  background-color: transparent;
  text-color:       @base05;

  margin:  0;
  padding: 0;
  spacing: 0;
}

window {
  width:            600px;
  background-color: @base00;
  border-radius:    12px;
  padding:          14px;
  location:         center;
  anchor:           center;
}

mainbox {
  children: [ inputbar, message, listview, mode-switcher ];
  spacing:  12px;
}

/* Search — a soft filled field, claude-style */
inputbar {
  background-color: @base01;
  border-radius:    8px;
  padding:          12px 16px;
  children:         [ prompt, entry ];
  spacing:          12px;
}

prompt {
  text-color: @base0E;
  font:       "MonaspiceNe Nerd Font Bold 12";
}

entry {
  text-color:        @base05;
  placeholder:       "SEARCH";
  placeholder-color: @base03;
  cursor-color:      @base0E;
}

message {
  background-color: @base01;
  border-radius:    8px;
  padding:          12px 16px;
}

textbox {
  text-color: @base05;
}

/* List — borderless rows, tight rhythm */
listview {
  lines:        8;
  columns:      1;
  fixed-height: false;
  padding:      0;
  spacing:      2px;
  scrollbar:    false;
}

element {
  padding:          9px 14px;
  border-radius:    6px;
  background-color: transparent;
  text-color:       @base05;
}

element-text {
  text-color:     inherit;
  vertical-align: 0.5;
}

element normal.normal, element alternate.normal {
  background-color: transparent;
  text-color:       @base05;
}

/* Selection is a soft fill, accent only in the text */
element selected.normal {
  background-color: @base02;
  text-color:       @base0E;
}

element normal.urgent, element alternate.urgent {
  background-color: transparent;
  text-color:       @base0A;
}

element selected.urgent {
  background-color: @base02;
  text-color:       @base0A;
}

element normal.active, element alternate.active {
  background-color: transparent;
  text-color:       @base08;
}

element selected.active {
  background-color: @base02;
  text-color:       @base08;
}

/* Mode strip — text-only, soft fill on the active tab */
mode-switcher {
  spacing: 8px;
}

button {
  padding:       8px 0;
  border-radius: 6px;
  text-color:    @base03;
}

button selected {
  background-color: @base01;
  text-color:       @base0E;
}
