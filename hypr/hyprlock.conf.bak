general {
    hide_cursor = true
    fail_timeout = 2000
}

animations {
    enabled = true
    bezier = linear, 1, 1, 0, 0
    animation = fadeIn, 1, 5, linear
    animation = fadeOut, 1, 5, linear
    animation = inputFieldDots, 1, 2, linear
}

background {
    monitor =
    path = ~/Pictures/pixel-car.png
    blur_size = 8 
    blur_passes = 4
    brightness = 0.7
}

# --- Center Elements ---

label {
    monitor = 
    text = $USER
    color = rgb(137, 180, 250)
    font_size = 50
    font_family = Monaspace Krypton Var
    position = 0, 150
    halign = center
    valign = center
}

input-field {
    monitor =
    size = 20%, 5%
    outline_thickness = 2
    inner_color = rgb(24, 24, 37)
    outer_color = rgb(17, 17, 27)
    check_color = rgb(180, 190, 254)
    fail_color = rgb(243, 139, 168)
    font_color = rgb(180, 190, 254)
    fade_on_empty = false
    rounding = 10
    font_family = Monaspace Radon Var
    placeholder_text = 
    fail_text = $PAMFAIL
    dots_text_format = x
    dots_spacing = 0.2
    position = 0, 0
    halign = center
    valign = center
}

label {
    monitor = 
    text = Login attempts: 
    font_size = 20
    font_family = Monaspace Neon Var
    color = rgb(137, 180, 250)
    position = -20, -125
    halign = center
    valign = center
}

label {
    monitor = 
    text = $ATTEMPTS
    font_size = 20
    font_family = Monaspace Neon Var
    color = rgb(137, 180, 250)
    position = 140, -125
    halign = center
    valign = center
}

# --- Bottom Left (Battery & Layout) ---

# Battery
label {
    monitor =
    text = cmd[update:1000] echo "<span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa'></span><span font='JetBrainsMono Nerd Font 24' background='##89b4fa' foreground='##1e1e2e'><b> BATTERY </b></span><span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa' background='##181825'></span><span font='JetBrainsMono Nerd Font 24' background='##181825' foreground='##cdd6f4'> $($HOME/.config/hypr/scripts/battery_hyprlock.sh) </span><span font='JetBrainsMono Nerd Font 24' foreground='##181825'></span>"
    position = 40, 90
    halign = left
    valign = bottom
}

# Layout
label {
    monitor =
    text = <span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa'></span><span font='JetBrainsMono Nerd Font 24' background='##89b4fa' foreground='##1e1e2e'><b> LAYOUT  </b></span><span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa' background='##181825'></span><span font='JetBrainsMono Nerd Font 24' background='##181825' foreground='##cdd6f4'>   $LAYOUT </span><span font='JetBrainsMono Nerd Font 24' foreground='##181825'></span>
    position = 40, 40
    halign = left
    valign = bottom
}

# --- Bottom Right (Time & Date) ---

# Time
label {
    monitor =
    text = <span font='JetBrainsMono Nerd Font 24' foreground='##181825'></span><span font='JetBrainsMono Nerd Font 24' background='##181825' foreground='##cdd6f4'> $TIME   </span><span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa' background='##181825'></span><span font='JetBrainsMono Nerd Font 24' background='##89b4fa' foreground='##1e1e2e'><b> TIME </b></span><span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa'></span>
    position = -40, 90
    halign = right
    valign = bottom
}

# Date
label {
    monitor =
    text = cmd[update:1000] echo "<span font='JetBrainsMono Nerd Font 24' foreground='##181825'></span><span font='JetBrainsMono Nerd Font 24' background='##181825' foreground='##cdd6f4'> $(date +'%a, %d %b')   </span><span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa' background='##181825'></span><span font='JetBrainsMono Nerd Font 24' background='##89b4fa' foreground='##1e1e2e'><b> DATE </b></span><span font='JetBrainsMono Nerd Font 24' foreground='##89b4fa'></span>"
    position = -40, 40
    halign = right
    valign = bottom
}
